  "flows": [
    {
      "unique-id": "transcript-flow",
      "name": "live transcript",
      "description": "raw transcript → cleaned 1:1 mirror → one render engine. The processed transcript has exactly one producer (agent-api); the terminal only renders.",
      "transitions": [
        {
          "relationship-unique-id": "bot-writes-segments-stream",
          "sequence-number": 1,
          "description": "bot confirms raw segments (ASR + LocalAgreement)"
        },
        {
          "relationship-unique-id": "collector-publishes-mutable",
          "sequence-number": 2,
          "description": "collector ingests + republishes change-only"
        },
        {
          "relationship-unique-id": "collector-writes-tc",
          "sequence-number": 3,
          "description": "collector writes the native per-meeting stream (single writer, P23)"
        },
        {
          "relationship-unique-id": "agent-writes-processed",
          "sequence-number": 4,
          "description": "worker cleans raw → processed 1:1 (catch-up then live)"
        },
        {
          "relationship-unique-id": "terminal-reads-processed",
          "sequence-number": 5,
          "description": "one engine renders raw|processed; no re-derivation"
        }
      ]
    }
  ]
