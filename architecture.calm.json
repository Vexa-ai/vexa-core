{
  "$schema": "https://calm.finos.org/release/1.0/meta/calm.json",
  "metadata": [
    {
      "vexa": {
        "purpose": "Data-flow + ownership registry (the dimension the gate suite did not model) AND the complete module/service/contract inventory. gate:dataflow enforces (a) model<->disk completeness, (b) single-writer + render-only ownership, (c) a reality diff against code.",
        "principle": "P23 — one writer per data carrier; readers never re-derive a producer's data; the model covers every module/service/contract (no drift)."
      }
    }
  ],
