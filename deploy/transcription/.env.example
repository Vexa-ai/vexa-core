# =============================================================================
# Transcription service (separate GPU deploy unit). Copy to .env:  cp .env.example .env
# =============================================================================

# Host port the nginx load balancer publishes (the stack points TRANSCRIPTION_SERVICE_URL here).
TRANSCRIPTION_LB_PORT=8083

# Model. Multilingual: tiny · base · small · medium · large-v2 · large-v3 · large-v3-turbo
# GPU recommendation: large-v3-turbo + int8 (~2.1 GB VRAM, >10x real-time, 99+ langs).
MODEL_SIZE=large-v3-turbo

# int8 (default; 50-60% VRAM cut, minimal accuracy loss) · float16 (GPU only, fastest, more VRAM)
COMPUTE_TYPE=int8

# CPU only (docker-compose.cpu.yml): physical cores, 0 = auto-detect.
CPU_THREADS=0

# Image tag built for the worker.
IMAGE_TAG=dev

# Shared secret. MUST equal TRANSCRIPTION_SERVICE_TOKEN in the main stack's .env.
# Empty = open (dev only). Set a strong value for any non-local deploy.
API_TOKEN=
