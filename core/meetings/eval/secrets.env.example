# meetings/eval — secrets (chmod 600, NEVER commit).
# The LIVE values already exist at ~/vexa-test-rig/secrets.env — run with:
#   SECRETS=~/vexa-test-rig/secrets.env EVAL_CACHE=~/vexa-test-rig/cache ./bin/eval.sh <stage>

# The service API that launches bots + serves /speak (the system-under-test).
#   0.11 baseline → the live deployment; 0.12 → meetings/services/meeting-api.
VEXA_BASE=https://api.vexa.ai

# The target meeting the bots join + speak into.
PLATFORM=google_meet           # google_meet | teams | zoom
NATIVE_ID=                     # the meeting's native id

# Where the captured transcript.v1 is read for scoring.
#   GET {TRANSCRIPTS_BASE}/transcripts/{platform}/{native} → { segments: [transcript.v1] }
TRANSCRIPTS_BASE=http://localhost:8056

# One service TEST-ACCOUNT token per speaker. A speaker is in the run iff its token is
# set — N tokens ⇒ an N-speaker meeting (cache holds 9 voices: A B V C D E F G H).
TOK_A=
TOK_B=
TOK_V=
TOK_C=
TOK_D=
# TOK_E=
# TOK_F=
# TOK_G=
# TOK_H=

# Deepgram key — ONLY to (re)generate the TTS clip pools (FORCE_REGEN=1). Not used per run.
DG_KEY=
