# config.env — knobs for the bot-local eval harness (cp to config.env; config.env is gitignored).
# Defaults shown are the proven O6 values; override per environment.

# ── target meeting (or pass `make run MEETING=<id>`) ──
# MEETING=rvf-kywf-pxb
PLATFORM=google_meet

# ── where the carved bot runs (the controllable VM, proven O6 path) ──
BBB_HOST=bbb                       # ssh host alias for the bot VM
VEXA_NET=vexa_vexa                 # docker network the compose stack + bot share
REDIS_CONTAINER=vexa-redis-1       # redis container (transcript.v1 stream + mutable channel)
RUNTIME_CONTAINER=vexa-runtime-api-1   # source of TRANSCRIPTION_SERVICE_URL/TOKEN for the bot config
BOT_IMAGE=vexaai/vexa-bot:v012     # the carved bot image on bbb
BOT_CONTAINER=bot-eval             # name for the spawned bot
MEETING_ID=999001                  # numeric inv.meeting_id (keys redis channels; reserved, collision-free)

# ── the local viewer (eyeball) ──
VIEWER_PORT=8090                   # → http://localhost:8090

# ── synthetic speakers (Vexa cloud control plane) ──
# SECRETS points to a file exporting VEXA_BASE, PLATFORM, NATIVE_ID, and the prod speaker tokens
# TOK_A..TOK_H (one per speaker). Decrypt from ~/dev/vexa-secrets; NEVER commit the tokens.
SECRETS=$HOME/vexa-test-rig/secrets.env
DURATION_S=180                     # how long to drive speakers
GAP_MEAN=-0.5                      # overlap dial (negative = speakers overlap)
WAIT_ADMIT_S=300                   # how long to wait for the human to admit the bot

# Keep things up after the run for inspection:
# KEEP_VIEWER=1
# KEEP_BOT=1
