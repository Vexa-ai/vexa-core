# meet-join runtime shape — the SOURCE OF TRUTH for the join layer's environment.
# Any service that assembles this brick builds FROM this image, instead of
# re-declaring the deps (MANIFEST P2/P6: runtime-shape is part of the contract;
# a service's env is the union of its bricks' shapes, depended-on not duplicated).
#
# Declares ONLY what the join code requires:
#   - Playwright + Chromium (the browser the brick drives)
#   - humanized X11 input: xvfb + xdotool + xclip  (without these the brick
#     silently degrades to synthetic input and gets bot-blocked)
#   - the live lens: x11vnc + novnc + websockify
#
# Build:  docker build -f Dockerfile.env -t vexa/meet-join-env:dev .
FROM mcr.microsoft.com/playwright:v1.56.0-jammy
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
      xvfb x11vnc websockify novnc xdotool xclip \
    && rm -rf /var/lib/apt/lists/*
