{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vexa.ai/schemas/runtime.v1",
  "title": "runtime.v1",
  "description": "The workload lifecycle contract between the control plane and the runtime kernel.",
  "$defs": {
    "RuntimeState": {
      "description": "The container/execution lifecycle state (NOT the workload's domain status).",
      "enum": ["starting", "running", "stopping", "stopped", "destroyed"]
    },
    "StopReason": {
      "enum": ["completed", "stopped", "idle_timeout", "failed", "oom", "start_failed", "max_lifetime"]
    },
    "Backend": { "enum": ["docker", "k8s", "process"] },
    "WorkloadSpec": {
      "description": "The create() input. The kernel runs this as an opaque profile + env.",
      "type": "object",
      "additionalProperties": false,
      "required": ["workloadId", "profile", "env"],
      "properties": {
        "workloadId": { "type": "string", "minLength": 1, "description": "caller-assigned id (idempotency key)" },
        "profile": { "type": "string", "minLength": 1, "description": "opaque workload kind, e.g. meeting-bot | agent" },
        "env": { "type": "object", "additionalProperties": { "type": "string" }, "description": "config-by-env (12-factor); a workload's repo URL + scoped token live here, not as a kernel concept" },
        "callbackUrl": { "type": "string", "format": "uri", "description": "where RuntimeEvents are POSTed" },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": "number", "minimum": 0 },
            "memoryMb": { "type": "integer", "minimum": 0 },
            "gpu": { "type": "integer", "minimum": 0 }
          }
        },
        "idleTimeoutSec": { "type": "integer", "minimum": 0 },
        "maxLifetimeSec": { "type": "integer", "minimum": 0 },
        "backend": { "$ref": "#/$defs/Backend" }
      }
    },
    "WorkloadStatus": {
      "description": "The kernel's view of a workload.",
      "type": "object",
      "additionalProperties": false,
      "required": ["workloadId", "profile", "state", "backend"],
      "properties": {
        "workloadId": { "type": "string" },
        "profile": { "type": "string" },
        "state": { "$ref": "#/$defs/RuntimeState" },
        "ports": { "type": "object", "additionalProperties": { "type": "integer" }, "description": "named → port, when running" },
        "startedAt": { "type": "string", "format": "date-time" },
        "stoppedAt": { "type": "string", "format": "date-time" },
        "exitCode": { "type": "integer" },
        "stopReason": { "$ref": "#/$defs/StopReason" },
        "backend": { "$ref": "#/$defs/Backend" },
        "node": { "type": "string", "description": "host / pod the workload runs on" }
      }
    },
    "RuntimeEvent": {
      "description": "The lifecycle callback the kernel POSTs to callbackUrl on each transition.",
      "type": "object",
      "additionalProperties": false,
      "required": ["workloadId", "state", "at"],
      "properties": {
        "workloadId": { "type": "string" },
        "state": { "$ref": "#/$defs/RuntimeState" },
        "at": { "type": "string", "format": "date-time" },
        "ports": { "type": "object", "additionalProperties": { "type": "integer" } },
        "exitCode": { "type": "integer" },
        "stopReason": { "$ref": "#/$defs/StopReason" }
      }
    }
  }
}
